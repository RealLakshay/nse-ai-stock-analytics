# ----------------------------
# Core Infrastructure
# ----------------------------
# For Docker Compose services
KAFKA_BROKER=redpanda:19092
DATABASE_URL=postgresql://stockuser:stockpass@postgres:5432/stockdb

# Kafka topics
KAFKA_TOPIC_RAW=stock.prices.raw
KAFKA_TOPIC_ANOMALIES=stock.anomalies

# ----------------------------
# LLM / Ollama
# ----------------------------
# If Ollama runs on host and services run in Docker, use host.docker.internal
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=mistral

# ----------------------------
# Market Configuration (NSE)
# ----------------------------
EXCHANGE=NSE
TICKER_SUFFIX=.NS
MARKET_OPEN_TIME=09:15
MARKET_CLOSE_TIME=15:30
MARKET_TIMEZONE=Asia/Kolkata

# ----------------------------
# ML / Detection
# ----------------------------
ANOMALY_ZSCORE_THRESHOLD=3.0
FORECAST_DAYS=7
ML_BATCH_SIZE=50
YFINANCE_ENABLED=true

# NSE ticker universe CSV
NSE_NIFTY500_CSV_URL=https://nsearchives.nseindia.com/content/indices/ind_nifty500list.csv

# ----------------------------
# Broker Credentials (optional)
# ----------------------------
# Kite
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

# Upstox
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_ACCESS_TOKEN=

# ----------------------------
# Alerts (optional)
# ----------------------------
ALERT_WEBHOOK_URL=
